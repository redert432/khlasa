rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAll(['createdAt'])
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) 
        && incoming().displayName is string && incoming().displayName.size() <= 100;
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'status'])
        && data.userId is string && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.createdAt == request.time
        && data.status is string && data.status.size() <= 50;
    }

    match /meetings/{meetingId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(meetingId) && isValidMeeting(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['transcript', 'summary', 'actionItems', 'status', 'title']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
